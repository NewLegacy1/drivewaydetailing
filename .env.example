# Supabase (client – used by the app to call the Edge Function)
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://gxhsgqwkfaicuqlrssed.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Supabase Edge Function secrets (set in Dashboard → Edge Functions → resend-email → Secrets) ---
# Do NOT put these in .env in your repo; set them in the Supabase Dashboard.
#
# SUPABASE_SERVICE_ROLE_KEY  = from Project Settings → API → service_role (secret)
# RESEND_API_KEY            = from https://resend.com/api-keys
# LEAD_EMAIL_TO             = contact@showroomautocare.ca
# LEAD_EMAIL_FROM           = leads@contact.newlegacyai.ca

# --- Blog: posts live in public/blog/data.json (text only, no stock images) ---
# GitHub Actions: add OPENAI_API_KEY under Repo → Settings → Secrets → Actions.
# Schedule: .github/workflows/daily-blog.yml (or run locally: npm run blog:generate).

# --- Google Business Profile (optional — shows CTAs + map when set) ---
# VITE_GMB_PROFILE_URL=https://share.google/... or maps.app.goo.gl / Google Maps place link
# VITE_GMB_REVIEW_URL=https://g.page/r/.../review  (GBP → Ask for reviews)
# VITE_GMB_MAP_EMBED_SRC=  ← paste ONLY the URL from src="...", not the whole <iframe> tag
#   Example: https://www.google.com/maps/embed?pb=!1m18!1m12!...

# --- Google Ads: /mobiledetailing quote form conversion (gtag send_to) ---
# Google Ads → Goals → Conversions → your conversion → Tag setup → copy "send_to" (AW-xxx/label).
# After submit, users land on /mobiledetailing/thank-you — use that URL for “page load” conversions too.
# VITE_GOOGLE_ADS_MOBILEDETAILING_SEND_TO=AW-16908239670/your_conversion_label
