{
  "redirects": [
    { "source": "/thank-you", "destination": "/", "permanent": false },
    { "source": "/thank-you/", "destination": "/", "permanent": false },
    { "source": "/ads/quote", "destination": "/ads/mobile-detailing", "permanent": false },
    { "source": "/ads/quote/", "destination": "/ads/mobile-detailing", "permanent": false },
    { "source": "/contact", "destination": "/#contact", "permanent": true },
